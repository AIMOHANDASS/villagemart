{
  "hosting": [
    {
      "target": "consumer",
      "public": "frontend/dist/client",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
        { "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "admin",
      "public": "frontend/dist/admin",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
        { "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "delivery",
      "public": "frontend/dist/delivery",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
        { "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "transport",
      "public": "frontend/dist/transport",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
        { "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ]
}